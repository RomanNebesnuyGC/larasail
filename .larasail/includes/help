#!/bin/bash

Color_Off="\033[0m"     # Text Reset
Yellow="\033[33m"       # Yellow
Cyan="\033[36m"         # Cyan

LARASAIL_VERSION=$(cat /etc/.larasail/VERSION 2>/dev/null || echo "unknown")
LARASAIL_REPO="https://github.com/RomanNebesnuyGC/larasail"

echo "${Yellow}LaraSail${Color_Off} version ${Cyan}${LARASAIL_VERSION}${Color_Off} — ${LARASAIL_REPO}"
echo ""

echo "${Yellow}Description:${Color_Off}"
echo "  CLI for building Laravel ready servers on DigitalOcean (Ubuntu 24)"
echo ""

echo "${Yellow}Usage:${Color_Off}"
echo "  larasail \$arguments"
echo ""

echo "${Yellow}Arguments:${Color_Off}"
echo "  ${Yellow}enter${Color_Off}                                Enter shell as larasail user"
echo "  ${Yellow}setup${Color_Off}                                Setup server: Nginx, PHP 8.5, MariaDB 11.8 LTS, Redis"
echo "  ${Yellow}setup php84${Color_Off}                          Setup with PHP 8.4 instead"
echo "  ${Yellow}setup php83${Color_Off}                          Setup with PHP 8.3 instead"
echo "  ${Yellow}setup php81${Color_Off}                          Setup with PHP 8.1 instead"
echo "  ${Yellow}setup php80${Color_Off}                          Setup with PHP 8.0 instead"
echo "  ${Yellow}setup php74${Color_Off}                          Setup with PHP 7.4 instead"
echo "  ${Yellow}setup mysql${Color_Off}                          Use MySQL 8 instead of MariaDB"
echo "  ${Yellow}setup pgsql${Color_Off}                          Use PostgreSQL instead of MariaDB"
echo "  ${Yellow}setup mariadb php84${Color_Off}                  Combine flags freely (order doesn't matter)"
echo "  ${Yellow}new${Color_Off}                                  Create a new Laravel project"
echo "  ${Yellow}host \$domain \$folder${Color_Off}                 ex: larasail host url.com /var/www/folder"
echo "  ${Yellow}hosts list${Color_Off}                           List all configured Nginx virtual hosts"
echo "  ${Yellow}database init${Color_Off}                        Create database, user & populate .env"
echo "  ${Yellow}database init --user NAME --db NAME${Color_Off}  Create with specific names"
echo "  ${Yellow}database list${Color_Off}                        List all user databases"
echo "  ${Yellow}database pass${Color_Off}                        Retrieve stored database passwords"
echo "  ${Yellow}pass${Color_Off}                                 Display the larasail user password"
echo "  ${Yellow}mysqlpass${Color_Off}                            Display the database admin password"
echo "  ${Yellow}version${Color_Off}                              Show installed version, repo, and changelog"
echo "  ${Yellow}changelog${Color_Off}                            Show full changelog"
echo "  ${Yellow}changelog \$version${Color_Off}                   Show changelog for a specific version (e.g. 2.0.1)"
echo "  ${Yellow}update${Color_Off}                               Update LaraSail to the latest version"
