#!/bin/bash

#/
#--------------------------------------------------------------------------
# Larasail Update
#--------------------------------------------------------------------------
#
# Re-downloads and installs the latest version of LaraSail.
#
#/

. /etc/.larasail/includes/colors
. /etc/.larasail/includes/format

setsail

bar
cyan "| Updating LaraSail "
bar

OLD_VERSION=$(cat /etc/.larasail/VERSION 2>/dev/null || echo "unknown")

cyan "| Current version: $OLD_VERSION"
cyan "| Downloading latest release..."
bar

TMPDIR=$(mktemp -d)
curl -sL https://github.com/RomanNebesnuyGC/larasail/archive/master.tar.gz | tar xz -C "$TMPDIR"

cyan "| Installing..."
sudo rm -rf /etc/.larasail
sudo mv "$TMPDIR/larasail-master/.larasail" /etc/.larasail
sudo cp "$TMPDIR/larasail-master/CHANGELOG.md" /etc/.larasail/CHANGELOG.md
rm -rf "$TMPDIR"
sudo mkdir -p /etc/.larasail/tmp
sudo chown -R larasail:larasail /etc/.larasail/tmp

NEW_VERSION=$(cat /etc/.larasail/VERSION 2>/dev/null || echo "unknown")

bar
green "| LaraSail updated: $OLD_VERSION -> $NEW_VERSION"
bar
