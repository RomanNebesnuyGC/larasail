#!/bin/bash

#/
#--------------------------------------------------------------------------
# Larasail Update
#--------------------------------------------------------------------------
#
# Re-downloads and installs the latest version of LaraSail.
#
#/

. /etc/.larasail/includes/colors
. /etc/.larasail/includes/format

setsail

bar
cyan "| Updating LaraSail "
bar

TMPDIR=$(mktemp -d)
curl -sL https://github.com/RomanNebesnuyGC/larasail/archive/master.tar.gz | tar xz -C "$TMPDIR"
rm -rf /etc/.larasail
mv "$TMPDIR/larasail-master/.larasail" /etc/.larasail
cp "$TMPDIR/larasail-master/CHANGELOG.md" /etc/.larasail/CHANGELOG.md
rm -rf "$TMPDIR"
chown -R larasail:larasail /etc/.larasail/tmp 2>/dev/null || true
